# ===== API server =====
API_PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/yuzibridge_menu
DB_SSL=false
CORS_ORIGIN=http://localhost:5173

# JWT for admin auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
GOOGLE_TRANSLATE_API_KEY=

# Frontend -> backend API (for MenuPage preview)
VITE_API_BASE_URL=http://localhost:4000

# Optional for Vercel proxy functions (/api/* and /uploads/*).
# Set this in Vercel Project Settings -> Environment Variables.
# Example: https://your-backend-domain.com
BACKEND_API_BASE_URL=

# Optional seed overrides
SEED_STORE_SLUG=dunwuzhai
SEED_STORE_BRAND_NAME=敦悟斋
SEED_ADMIN_EMAIL=admin+dunwuzhai@yuzibridge.com
SEED_ADMIN_PASSWORD=ChangeMe123!
